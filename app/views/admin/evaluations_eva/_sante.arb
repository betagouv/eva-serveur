h3 t(categorie.to_sym, scope: [ :admin, :evaluations_eva, :questions_reponses_autopositionnement ]),
class: "categorie"
questions_reponses.each do |question, reponse|
  if question.categorie == categorie
    div question.transcription_intitule&.ecrit
    div reponse.intitule, class: "reponse"
  end
end
