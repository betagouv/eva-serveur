<div class='referentiel_anlci bg-information'>
  <% scope = "admin.restitutions.references" %>
  <div class='fr-grid-row marges-page'>
    <div class='fr-col-12'>
      <div class='fr-grid-row'>
        <div class='fr-col-12 fr-col-md-1 col-icone-info'>
          <div><%= image_tag "info.svg", class: "icone", alt: "Information" %></div>
        </div>
        <div class='fr-col-12 fr-col-md-11'>
          <div class='texte-explications'>
            <%= md t("explications-anlci", scope: scope) %>
          </div>
          <div class='fr-col badges-referentiels'>
            <% @badges_referentiel.each do |badge| %>
              <%= image_tag "badges/anlci/#{badge}-referentiel.svg",
                            class: "badge-references",
                            alt: t(badge, scope: scope) %>
            <% end %>
          </div>
          <div class='texte-explications'>
            <%= md t("explications-lien", scope: scope) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
