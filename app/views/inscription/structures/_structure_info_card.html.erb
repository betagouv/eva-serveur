      <span class="structure-info-card__label"><%= Structure.human_attribute_name(:siret) %> :</span> <span class="structure-info-card__value"><%= formater_siret(structure.siret) %></span>
    </li>
    <li class="structure-info-card__info">
      <span class="structure-info-card__label"><%= Structure.human_attribute_name(:raison_sociale) %> :</span> <span class="structure-info-card__value"><%= structure&.raison_sociale %></span>
