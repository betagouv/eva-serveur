<div class="fr-table" id="table-0-component">
  <div class="fr-table__wrapper">
    <div class="fr-table__container">
      <div class="fr-table__content">
        <table id="table-0">
          <caption><%= titre %></caption>
          <thead>
            <tr style="border-bottom-color: $grey-200;">
              <% colonnes.each do |colonne| %>
                <th><%= colonne[:titre] %></th>
              <% end %>
              <% if actions == true %>
                <th></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% collection.each_with_index do |item, index| %>
              <tr id="table-0-row-key-<%= index + 1 %>" data-row-key="<%= index + 1 %>">
                <% colonnes.each do |colonne| %>
                  <td><%= capture(item, &colonne[:block]) %></td>
                <% end %>
                <% if actions == true %>
                  <td>
                    <div class="menu-actions">
                      <div class="table_actions">
                          <%= link_to t(".voir"), polymorphic_path([:admin, item]) %>
                          <%= link_to t(".modifier"), edit_polymorphic_path([:admin, item]) %>
                          <%= link_to t(".supprimer"),
                                      polymorphic_path([:admin, item]),
                                      method: :delete,
                                      data: { confirm: t(".confirmation_suppression") } %>
                      </div>
                    </div>
                    <%= render partial: "components/bouton_menu_actions" %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>