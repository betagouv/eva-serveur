<div class="structure-parametrage-section">  
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col-12">
      <%= render InputComponent.new(
        id: "structure_nom",
        label: t("inscription.structures.show.nom_structure_label"),
        form: form,
        method: :nom,
        type: "text",
        hint: t("inscription.structures.show.hint_nom_structure"),
        required: true,
        value: form.object.nom.presence || form.object.raison_sociale
      ) %>
    </div>
    <% if structure_necessite_saisie_code_postal?(form.object) %>
      <div class="fr-col-12">
        <%= render CodePostalInputComponent.new(
          id: "structure_code_postal",
          label: t("inscription.structures.show.code_postal_label"),
          hint: t("inscription.structures.show.code_postal_hint"),
          form: form,
          method: :code_postal,
          value: form.object.code_postal,
          required: true
        ) %>
      </div>
    <% end %>
    <div class="fr-col-12">
      <%= render InputComponent.new(
        id: "structure_type_structure",
        label: t("inscription.structures.show.type_structure_label"),
        form: form,
        method: :type_structure,
        as: :select,
        collection: collection_types_structures,
        include_blank: t("inscription.structures.show.choisir_type"),
        required: true
      ) %>
    </div>
    <div class="fr-col-12">
      <%= render InputComponent.new(
        id: "structure_opco_id",
        label: t("inscription.structures.show.opco_label"),
        form: form,
        method: :opco_id,
        collection: collection_opcos,
        required: true,
        value: opco_id_associe(form.object),
        hint: t("inscription.structures.show.hint_opco"),
        include_blank: t("inscription.structures.show.choisir_opco"),
        link_text: "Trouver mon Opérateur de compétences sur France Compétences",
        link_url: "https://quel-est-mon-opco.francecompetences.fr/",
        link_html: { target: "_blank", rel: "noopener noreferrer" }
      ) %>
    </div>
    <div class="fr-col-12">
      <%= render EmailInputComponent.new(
        id: "structure_email_contact",
        label: t("inscription.structures.show.email_contact_label"),
        hint: t("inscription.structures.show.email_contact_hint"),
        form: form,
        method: :email_contact,
        value: form.object.email_contact,
        required: false,
        input_html: { placeholder: "" }
      ) %>
    </div>
    <div class="fr-col-12">
      <%= render NumeroTelephoneInputComponent.new(
        id: "structure_telephone",
        label: t("inscription.structures.show.telephone_label"),
        hint: t("inscription.structures.show.telephone_hint"),
        form: form,
        method: :telephone,
        value: form.object.telephone,
        required: false,
        input_html: { placeholder: "" }
      ) %>
    </div>
  </div>
</div>

