<%= dsfr_modal(title: t(".titre").html_safe, html_attributes: { id: "fr-modal-fusionner" }) do %>
  <div class="modal-fusionner">
    <%= form_with url: batch_action_admin_beneficiaires_path, method: :post, local: true, id: "fusion-form" do |f| %>
      <div class= "liste-beneficiaires-fusion"style="padding-bottom: 60px">
        <p>En cliquant sur "Confirmer", vous validez la fusion des comptes suivants :</p>
        <ul id="liste-elements-a-fusionner"></ul>
        <p>Après la fusion, toutes les évaluations seront rattachées au bénéficiaire <span class="fr-text--bold" id="beneficiaire-rattache"></span>.</p>
      </div>


      <%= hidden_field_tag :batch_action, "fusionner" %>      
      <%= hidden_field_tag :batch_action_inputs, "{}" %>
      
      <div id="hidden-ids-container"></div>
      
      <div class="fr-modal__footer">
        <button type="button" class="fr-btn bouton-secondaire" data-dismiss="modal">Annuler</button>
        <button type="submit" class="fr-btn" id="confirmer-fusion">Confirmer</button>
      </div>
    <% end %>
  </div>
<% end %>
