<div class='mise-en-action__texte d-flex justify-content-center text-center' data-reponse="">
  <% mise_en_action_presenter = evaluation.usage.mise_en_action_presenter %>
  <%= render partial: "components/modification_mise_en_action",
    locals: { reponse_mise_en_action: true,
              mise_en_action: evaluation&.mise_en_action,
              affiche_qualification: affiche_qualification,
              modification_affichee: mise_en_action_presenter.a_mise_en_action? && mise_en_action_presenter.effectuee_avec_remediation?
            } %>
  <%= render partial: "components/modification_mise_en_action",
    locals: { reponse_mise_en_action: false,
              mise_en_action: evaluation&.mise_en_action,
              affiche_qualification: affiche_qualification,
              modification_affichee: mise_en_action_presenter.a_mise_en_action? && mise_en_action_presenter.non_effectuee_avec_difficulte? } %>

  <% classe_reponse_en_attente = mise_en_action_presenter.a_mise_en_action? && mise_en_action_presenter.mise_en_action_avec_qualification? ? "hidden" : "d-flex" %>
  <% classe_reponse_oui = mise_en_action_presenter.a_mise_en_action? && evaluation.mise_en_action.effectuee? ? " bouton--actif" : "" %>
  <% classe_reponse_non = mise_en_action_presenter.a_mise_en_action? && !evaluation.mise_en_action.effectuee? ? " bouton--actif" : "" %>
  <div data-reponse="vide" class="actions mise-en-action <%= classe_reponse_en_attente %>">
    <%= render BoutonDsfrComponent.new(
      "#",
      type: :secondary,
      tag: :button,
      size: :sm,
      class: "reponse-mise-en-action#{classe_reponse_oui}",
      data: { reponse: "true" },
      "aria-describedby": "question-diagnostics nom-#{evaluation.id}",
      "aria-expanded": "false"
    ) do %>
      <%= t(".bouton_oui") %>
    <% end %>
    
    <%= render BoutonDsfrComponent.new(
      "#",
      type: :secondary,
      tag: :button,
      size: :sm,
      class: "reponse-mise-en-action#{classe_reponse_non}",
      data: { reponse: "false" },
      "aria-describedby": "question-diagnostics nom-#{evaluation.id}",
      "aria-expanded": "false"
    ) do %>
      <%= t(".bouton_non") %>
    <% end %>
  </div>
</div>
