<div class="fr-table" id="table-0-component">
  <div class="fr-table__wrapper">
    <div class="fr-table__container">
      <div class="fr-table__content">
        <table id="table-0">
          <caption><%= titre %></caption>
          <thead>
            <tr style="border-bottom-color: $grey-200;">
              <% colonnes.each do |colonne| %>
                <th><%= colonne[:titre] %></th>
              <% end %>
              <% if actions == true %>
                <th></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% collection.each_with_index do |item, index| %>
              <tr id="table-0-row-key-<%= index + 1 %>" data-row-key="<%= index + 1 %>">
                <% colonnes.each do |colonne| %>
                  <td><%= capture(item, &colonne[:block]) %></td>
                <% end %>
                <% if actions == true %>
                  <td class="tableau-boutons-action">
                    <%= render MenuBoutonsActionComponent.new(
                        { label: "Voir", url: "#" },
                        { label: "Modifier", url: "#" },
                        { label: "Supprimer", url: "#", method: :delete, data: { confirm: "Voulez-vous supprimer ?" } }
                      ) %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>