<div id="profil">
  <div class="page adaptation-pdf profil">
    <%= render "admin/evaluations/eva/entete_page", restitution_globale: @restitution_globale %>

    <h2 class="text-center fr-mt-12v fr-mb-6v evaluation__titre"><%= t("admin.evaluations.restitution_globale.autopositionnement.titre") %></h2>

    <div class="panel">
      <div class="marges-page">
        <%= render partial: "admin/evaluations/eva/questions_reponses_autopositionnement", locals: { bienvenue: @bienvenue } %>
      </div>

      <%= render "admin/evaluations/eva/pied_page" %>
    </div>
  </div>

  <% if @bienvenue.inclus_autopositionnement? %>
    <div class="page adaptation-pdf profil">
      <%= render "admin/evaluations/eva/entete_page", restitution_globale: @restitution_globale %>

      <div class="panel">
        <div class="marges-page">
          <%= render partial: "admin/evaluations/eva/questionnaire_autopositionnement", locals: { auto_positionnement: @bienvenue } %>
        </div>

        <%= render "admin/evaluations/eva/pied_page" %>
      </div>
    </div>
  <% end %>
</div>
