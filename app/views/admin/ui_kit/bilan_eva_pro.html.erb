<div class="container uik-max-active-admin">
  <h1>Démo BilanEvaProComponent</h1>

  <p class="fr-text--lead">
    Ce composant affiche le bilan Eva Pro avec un mot clé et une explication selon le palier.
  </p>

  <h2>Tous les paliers</h2>

  <% %i[A B C D].each do |palier_label, _palier_key| %>
    <div class="fr-mb-5w">
      <h3>Palier <%= palier_label %></h3>
      <%= render BilanEvaProComponent.new(palier: palier_label) %>
    </div>
  <% end %>
</div>
