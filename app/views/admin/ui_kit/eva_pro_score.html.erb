<div class="container">
  <div class="fr-mb-3w">
    <%= link_to "← Retour à l'index des composants", "/admin/ui_kit", class: "fr-link" %>
  </div>

  <h1>Démo EvaProScoreComponent</h1>

  <p class="fr-text--lead">
    Composant de paliers Evaproscore (A, B, C, D) pour remplacer l'impact stepper.
  </p>

  <div style="display: flex; gap: 3rem; flex-wrap: wrap; align-items: flex-start; margin-bottom: 1rem;">
    <%# EvaProScoreComponent - une ligne par palier actif %>
    <section>
      <h2>Evaproscore</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <% %w[A B C D].each do |active_letter| %>
          <div>
            <%= render EvaProScoreComponent.new(active_letter:) %>
          </div>
        <% end %>
      </div>
    </section>

    <%# EvaProScoreItemComponent - chaque lettre à chaque état %>
    <section>
      <h2>Evaproscore - États des items</h2>
      <div style="display: flex; gap: 2rem;">
        <div>
          <h3 style="font-size: 0.875rem; margin-bottom: 0.5rem;">Inactif</h3>
          <div style="display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start;">
            <% %w[A B C D].each do |letter| %>
              <%= render EvaProScoreItemComponent.new(letter:, active: false) %>
            <% end %>
          </div>
        </div>
        <div>
          <h3 style="font-size: 0.875rem; margin-bottom: 0.5rem;">Actif</h3>
          <div style="display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start;">
            <% %w[A B C D].each do |letter| %>
              <%= render EvaProScoreItemComponent.new(letter:, active: true) %>
            <% end %>
          </div>
        </div>
      </div>
    </section>
  </div>

  <section>
  <h2>Utilisation à la restitution des impacts</h2>
  <div style="max-width: 880px;"> <!-- simulation de la largeur max active admin --!>
    <% Evaluations::DiagnosticPro::SCORE_TO_LETTRE.each_key do |score| %>
      <h3>niveau <%= score %></h3>
      <% synthese = Evaluations::DiagnosticPro::ImpactsPresenter::INTERPRETATIONS
        .each_with_object({}) { |interpretation, synthese| synthese[interpretation] = score } %>
      <%= render partial: "admin/evaluations/evapro/mesure_des_impacts_chart",
        locals: { synthese: synthese, interpretations_impact: synthese.keys } %>
    <% end %>

  </div>
  </section>
</div>
