div class: "page-structure" do
  div class: "structure" do
    div class: "bloc-structure-infos" do
      render "components/panel_introduction",
              text: t(".introduction", lien_aide: admin_aide_path),
              image: "bienvenue.png"

      div class: "panel" do
        attributes_table_for structure do
          row :nom
          row :siret do
            FormatageSiretHelper.formater_siret(structure.siret)
          end
          if structure.instance_of?(StructureOpco)
            row("Opérateur de compétences") do
              structure.opco.nom
            end
          end
          if structure.instance_of?(StructureLocale)
            row :type_structure do
              traduction_type_structure(structure.type_structure)
            end
            if current_compte.superadmin?
              row :usage
              row :opco do
                affiche_opcos(structure)
              end
            end
            row :code_postal
            if current_compte.superadmin?
              row :statut_siret do
                render BadgeComponent.new(
                  contenu: format_statut_siret(structure.statut_siret),
                  class_couleur: structure.statut_siret ? "fr-badge--green-emeraude" : ""
                )
              end
              row :date_verification_siret do
                structure.date_verification_siret&.strftime("%d/%m/%Y %H:%M")
              end
              row :code_naf
              row :idcc do
                structure.idcc.join(", ")
              end
              row :raison_sociale
              row :adresse
            end
            row :autorisation_creation_campagne do
              render(BadgeComponent.new(
                contenu: traduction_autorisation_creation_campagne(
                  resource.autorisation_creation_campagne
                ),
                class_couleur: badge_class(structure.autorisation_creation_campagne))
              )
            end
            row :code_commune
            row :region
          end
          row :created_at
        end
      end

      render "admin/structures/membres"

      if resource.is_a?(StructureLocale) && !resource.evapro?
        render partial: "admin/structures/mes_campagnes", locals: { campagnes: campagnes }
      end
    end
  end
  div do
    unless resource.evapro?
      section id: "bloc-statistiques" do
        render partial: "admin/structures/statistiques"
      end
    end

    if can?(:manage, Compte)
      section do
        panel "Administration" do
          attributes_table_for structure do
            row :id
            row :updated_at
            row :structure_referente
            if structure.instance_of?(StructureAdministrative)
              row :structures_dependantes do
                structure.children
              end
            end
          end
        end
      end
    end

    section active_admin_comments_for(resource)
  end
end
