<% id_modal = "fr-modal-confirmation-cgu" %>
<%# Déclencheur hors <dialog> : voir _modal_validation_comptes_en_attente.html.erb %>
<button type="button"
        class="fr-btn fr-sr-only"
        data-fr-opened="true"
        aria-controls="<%= id_modal %>"
        tabindex="-1">
  <%= t(".ouverture_initiale_libelle_bouton") %>
</button>

<%= dsfr_modal(
  title: t(".titre"),
  opened: true,
  html_attributes: {
    id: id_modal,
    class: "fr-modal-confirmation-cgu fr-modal-dashboard-evapro evapro_admin",
    "data-fr-concealing-backdrop": "false"
  }
) do %>
  <div class="fr-alert fr-alert--info">
    <div class="message">
      <%= render partial: "admin/comptes/demande_acceptation_cgu_creation_compte",
        locals: { scope: "admin.dashboard.modal_confirmation_cgu" } %>
    </div>
    <div class="fr-modal-dashboard-evapro__actions">
      <%= render BoutonDsfrComponent.new(
        accepter_cgu_admin_compte_path(current_compte),
        type: :primary,
        tag: :button_with_form,
        size: :sm,
        method: :patch,
        form: { data: { turbo: false } }
      ) do %>
        <%= t(".bouton_acceptation_cgu") %>
      <% end %>
    </div>
  </div>
<% end %>
