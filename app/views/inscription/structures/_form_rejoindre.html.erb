<%= semantic_form_for @compte, url: inscription_structure_path do |form| %>
  <%= form.semantic_errors *champs_non_affiches(form.object.errors.messages.keys, []) %>

  <%= form.inputs do %>
    <%= render CarteV2Component.new(titre: t("inscription.structures.show.titre_carte"), sous_titre: t("inscription.structures.show.sous_titre_carte")) do %>
      <div class="structure-content-wrapper-container">
      <div class="structure-content-wrapper">
        <%= render "structure_info_card", structure: @structure %>
        <% if @structures_meme_siret.count > 1 %>
          <div class="structure-content-wrapper-siret">
            <div class="structure-content-wrapper-siret_titre_container">
              <p class="structure-content-wrapper-siret_titre"> <%= t("inscription.structures.show.titre_siret_multiple") %></p>
              <p class="structure-content-wrapper-siret_texte"> <%= t("inscription.structures.show.sous_titre_siret_multiple") %></p>
            </div>
            <% @structures_meme_siret.each do |structure| %>
              <div class="fr-fieldset__element">
                <div class="fr-radio-group fr-radio-group--sm">
                  <%= form.radio_button :structure_id, structure.id, id: "structure_#{structure.id}" %>
                  <%= form.label :structure_id, structure.nom.upcase, class: "fr-label", for: "structure_#{structure.id}" %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        
        <%= form.input :structure_confirmee, as: :boolean, label: t("inscription.structures.show.confirme_structure"), required: false %>

        <% if @structures_meme_siret.count <= 1 %>
           <p class="structure-confirmation-mention">
            <%= t("inscription.structures.show.mention_acces") %>
          </p>
        <% end %>
      </div>
      <div class="informations-compte-actions">
        <%= render BoutonDsfrComponent.new(
          t("inscription.structures.show.ce_nest_pas_ma_structure"),
          type: :tertiary,
          tag: :submit,
          submit_value: "recherche",
          formaction: inscription_structure_path(action_type: "recherche")
        ) do %>
          <%= t("inscription.structures.show.ce_nest_pas_ma_structure") %>
        <% end %>
        <%= render BoutonDsfrComponent.new(
          t("inscription.structures.show.rejoindre"),
          type: :primary,
          tag: :submit,
          submit_value: "rejoindre",
          id: "rejoindre-structure-btn",
          disabled: true
        ) do %>
          <%= t("inscription.structures.show.rejoindre") %>
        <% end %>
      </div>
      </div>
    <% end %>
  <% end %>
<% end %>

