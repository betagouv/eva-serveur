diagnostic_pro = evaluation.diagnostic_pro.with_restitution_globale(restitution_globale)
diag_risques_entreprise = diagnostic_pro.diag_risques_entreprise
pourcentage_risque = diagnostic_pro.pourcentage_risque
evaluation_impact_general = nil

div class: "evaluation-evapro" do
  div class: "page page__evapro adaptation-pdf" do
    if pdf
      render(Pdf::HeaderEvaproComponent.new(
        date: evaluation.debutee_le,
        beneficiaire: evaluation.beneficiaire.nom,
        structure: restitution_globale.evaluation.structure
      ))
    end
    div class: "page__contenu" do
      if !pdf
        div class: "evaluation-evapro__titre-container" do
          h1 evaluation.diagnostic_pro.titre, class: "evaluation-evapro__titre"
          if pourcentage_risque
            url = admin_evaluation_path(evaluation, format: :pdf)
            render(BoutonDsfrComponent.new(
              url,
              type: :primary,
              size: :sm,
              class: "fr-icon-download-line fr-btn--icon-left").with_content("Exporter")
            )
          end
        end
      end

      if diag_risques_entreprise && pourcentage_risque
        risques_presenter = diagnostic_pro.risques_presenter
        render(
          partial: "mesure_des_risques",
          locals: { risques_presenter: risques_presenter, pdf: pdf }
        )
      end

      if pourcentage_risque
        evaluation_impact_general = diagnostic_pro.evaluation_impact_general
        complet = diagnostic_pro.complet?
        impacts_presenter = diagnostic_pro.impacts_presenter(evaluation_id: evaluation.id)
        render(
          partial: "mesure_des_impacts",
          locals: {
            evaluation_impact_general: evaluation_impact_general,
            impacts_presenter: impacts_presenter,
            pdf: pdf,
            complet: complet
          }
        )

        if complet
          couts_presenter = diagnostic_pro.couts_presenter(
            synthese: diagnostic_pro.synthese_impact_general,
            i18n: self
          )
          render(
            partial: "impact_couts",
            locals: {
              synthese: diagnostic_pro.synthese_impact_general,
              couts_presenter: couts_presenter,
              pdf: pdf,
              complet: complet
            }
          )
        end
      end
    end
  end

  if diagnostic_pro.affiche_bilan?
    div class: "page page__evapro adaptation-pdf" do
      if pdf
        render(Pdf::HeaderEvaproComponent.new(
          date: evaluation.debutee_le,
          beneficiaire: evaluation.beneficiaire.nom,
          structure: restitution_globale.evaluation.structure
        ))
      end
      div class: "page__contenu" do
        render(
          partial: "bilan_evapro",
          locals: {
            diag_risques_entreprise: diag_risques_entreprise,
            palier_risque: diagnostic_pro.palier_risque,
            opco: evaluation.diagnostic_pro.opco,
            pdf: pdf
          }
        )

        render(
          partial: "aller_plus_loin",
        )
      end
    end
  end
end
