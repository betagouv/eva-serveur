context.instance_eval do
  column :beneficiaire, class: "evaluation__col-beneficiaire" do |evaluation|
    render partial: "admin/evaluations_eva/beneficiaire", locals: { evaluation: evaluation }
  end

  if affiche_colonne_structure?
    column :structure, class: "evaluation__col-structure" do |evaluation|
      evaluation.campagne.structure.display_name
    end
  end

  column :campagne, class: classes_colonne_campagne(affiche_colonne_structure?) do |evaluation|
    campagne = evaluation.campagne
    div class: "evaluation__cellule" do
      div campagne.display_name, class: "evaluation__campagne"
      parcours_type = campagne.parcours_type
      if affiche_sous_titre_campagne?(parcours_type)
        div parcours_type.display_name,
          class: "evaluation__campagne-sous-titre"
      end
    end
  end

  column :debutee_le do |evaluation|
    evaluation.debutee_le.strftime("%d/%m/%Y")
  end

  column "" do |evaluation|
    render partial: "admin/evaluations/lien",
      locals: { chemin: admin_evaluation_eva_path(evaluation) }
  end
end
