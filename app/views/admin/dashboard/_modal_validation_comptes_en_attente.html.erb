<% id_modal = "fr-modal-validation-comptes-en-attente" %>
<%# Déclencheur hors <dialog> : le ModalsGroup DSFR exige un bouton primaire data-fr-opened="true"
    pour isInitiallyDisclosed ; sinon getIndex(-1) referme toutes les modales au chargement. %>
<button type="button"
        class="fr-btn fr-sr-only"
        data-fr-opened="true"
        aria-controls="<%= id_modal %>"
        tabindex="-1">
  <%= t(".ouverture_initiale_libelle_bouton") %>
</button>

<%= dsfr_modal(
  title: t(".titre"),
  opened: true,
  html_attributes: {
    id: id_modal,
    class: "fr-modal-validation-comptes fr-modal-dashboard-evapro evapro_admin",
    "data-fr-concealing-backdrop": "true"
  }
) do |component| %>
  <div class="fr-alert fr-alert--warning">
    <div class="message">
      <%= md t(".info_comptes_en_attente") %>
    </div>
    <div class="fr-modal-dashboard-evapro__actions">
      <%= render BoutonDsfrComponent.new(
        "#",
        type: :secondary,
        tag: :button,
        size: :sm,
        "aria-controls": id_modal
      ) do %>
        <%= t(".annuler") %>
      <% end %>

      <%= render BoutonDsfrComponent.new(
        admin_comptes_path,
        type: :primary,
        tag: :a,
        size: :sm
      ) do %>
        <%= t(".voir_les_demandes") %>
      <% end %>
    </div>
  </div>
<% end %>
