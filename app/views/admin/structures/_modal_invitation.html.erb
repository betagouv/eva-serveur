<% id_modal = "fr-modal-invitation-#{structure.id}" %>
<% form_id = "invitation-form-#{structure.id}" %>

<%= dsfr_modal(
  title: t("admin.structures.membres.modal.titre"),
  html_attributes: { id: id_modal, class: "fr-modal-invitation evapro_admin" }
) do |component| %>
  <div class="contenu-modale">
    <div class="contenu">
      <%= form_with url: envoyer_invitation_admin_structure_locale_path(structure),
                    method: :post,
                    local: true,
                    scope: :invitation,
                    html: { id: form_id } do |f| %>
        <p class="invitation-modal-description">
          <%= t("admin.structures.membres.modal.description") %>
        </p>

        <%= render InputComponent.new(
          id: "invitation_email_#{structure.id}",
          form: f,
          method: :email,
          type: "email",
          label: t("admin.structures.membres.modal.email_label"),
          required: true
        ) %>

        <% if current_compte.au_moins_admin? %>
          <div class="fr-select-group">
            <label class="fr-label" for="invitation_role_<%= structure.id %>">
              <%= t("admin.structures.membres.modal.role_label") %>
            </label>
            <%= f.select :role,
                         options_for_select(
                           Compte::ROLES_STRUCTURE.map { |r| [ t("admin.structures.membres.modal.roles.#{r}"), r ] },
                           nil
                         ),
                         { include_blank: t("admin.structures.membres.modal.role_placeholder") },
                         id: "invitation_role_#{structure.id}",
                         class: "fr-select" %>
          </div>
        <% end %>

        <div class="fr-input-group">
          <label class="fr-label" for="invitation_message_<%= structure.id %>">
            <%= t("admin.structures.membres.modal.message_label") %>
            <span class="fr-hint-text"><%= t("admin.structures.membres.modal.message_hint") %></span>
          </label>
          <%= f.text_area :message,
                          id: "invitation_message_#{structure.id}",
                          class: "fr-input",
                          rows: 4 %>
        </div>
      <% end %>
    </div>
  </div>

  <% component.with_button do %>
    <%= render BoutonDsfrComponent.new(
      t("admin.structures.membres.modal.envoyer"),
      type: :primary,
      tag: :submit,
      form: form_id,
      class: "fr-icon-send-plane-fill"
    ) do %>
      <%= t("admin.structures.membres.modal.envoyer") %>
    <% end %>
  <% end %>

  <% component.with_button do %>
    <%= button_tag type: "button",
                   class: "fr-btn fr-btn--primary copier-lien-invitation",
                   data: {
                     copier_lien_url: copier_lien_admin_structure_locale_path(structure)
                   } do %>
      <span class="fr-icon-links-fill" aria-hidden="true"></span>
      <span class="copier-lien-invitation__label"><%= t("admin.structures.membres.modal.copier_lien") %></span>
    <% end %>
  <% end %>
<% end %>
