<div class="container uik-max-active-admin">
  <h1>Démo MesureChiffreCleComponent</h1>

  <p class="fr-text--lead">
    Ce composant affiche une mesure avec un chiffre clé et deux paragraphes d'explication selon le palier.
  </p>

  <h2>Exemple avec prefix</h2>

  <div class="fr-mb-5w">
    <%= render Evaluation::MesureChiffreCleComponent.new(
      palier: "A",
      chiffre: "10 %",
      prefixe: "Taux de risque",
      explications: {
        texte: "Ce pourcentage de masse salariale est une estimation de ce que coûte à votre organisation le fait de compter des salariés / agents en difficulté avec les compétences de base dans vos effectifs.",
        suite: "À 1 %, l'impact reste limité. Les quelques difficultés en compétences de base de vos salariés / agents génèrent peu de coûts et n'entravent pas significativement l'activité."
      }
    ) %>
  </div>

  <h2>Exemple avec suffixe</h2>

  <div class="fr-mb-5w">
    <%= render Evaluation::MesureChiffreCleComponent.new(
      palier: "A",
      chiffre: "1 %",
      suffixe: "de votre masse salariale",
      explications: {
        texte: "Ce pourcentage de masse salariale est une estimation de ce que coûte à votre organisation le fait de compter des salariés / agents en difficulté avec les compétences de base dans vos effectifs.",
        suite: "À 1 %, l'impact reste limité. Les quelques difficultés en compétences de base de vos salariés / agents génèrent peu de coûts et n'entravent pas significativement l'activité."
      }
    ) %>
  </div>

  <h2>Exemple avec préfixe uniquement</h2>

  <div class="fr-mb-5w">
    <%= render Evaluation::MesureChiffreCleComponent.new(
      palier: "B",
      prefixe: "Score",
      chiffre: "75",
      explications: {
        texte: "Votre score indique une situation à surveiller.",
        suite: "Il est recommandé de mettre en place des actions préventives pour éviter que la situation ne se dégrade."
      }
    ) %>
  </div>

  <h2>Exemple sans préfixe ni suffixe</h2>

  <div class="fr-mb-5w">
    <%= render Evaluation::MesureChiffreCleComponent.new(
      palier: "C",
      chiffre: "50",
      explications: {
        texte: "Votre situation nécessite une attention particulière.",
        suite: "Des actions correctives sont recommandées pour améliorer la situation."
      }
    ) %>
  </div>

  <h2>Tous les risques</h2>

  <% scope = [ :admin, :evaluations, :mesure_des_risques ] %>
  <% Evaluations::DiagnosticPro::RisquesPresenter::SEUILS_PALIERS_RISQUE.each do |pourcentage, palier_label| %>
    <% presenter = Evaluations::DiagnosticPro::RisquesPresenter.new(pourcentage_risque: pourcentage) %>
    <div class="fr-mb-5w">
      <h3>Palier <%= presenter.palier %></h3>
      <%= render Evaluation::MesureChiffreCleComponent.new(
        palier: presenter.palier,
        prefixe: t(:prefixe, scope: scope),
        chiffre: "#{pourcentage} %",
        explications: {
          texte: t("explication.texte.#{presenter.palier}", scope: scope),
          suite: t("explication.suite.#{presenter.palier}", scope: scope)
        }
      ) %>
    </div>
  <% end %>

  <h2>Tous les coûts</h2>

  <% Evaluations::DiagnosticPro::SCORE_TO_LETTRE.each_key do |score| %>
    <% presenter = Evaluations::DiagnosticPro::CoutsPresenter.new(
      synthese: { score_cout: score.to_sym },
      i18n: self
    ) %>
    <% contenu_cout = presenter.contenu_cout %>
    <div class="fr-mb-5w">
      <h3>Palier <%= presenter.lettre(:score_cout) %></h3>
      <%= render Evaluation::MesureChiffreCleComponent.new(
        palier: presenter.lettre(:score_cout),
        chiffre: contenu_cout[:titre],
        suffixe: t("admin.evaluations.evapro.impact_couts.suffixe_masse_salariale"),
        explications: {
          texte: contenu_cout[:texte],
          suite: contenu_cout[:suite]
        }
      ) %>
    </div>
  <% end %>
</div>
