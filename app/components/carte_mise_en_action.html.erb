<li id="<%= @ressource.id %>" class="carte__conteneur position-relative pb-0">
  <div class="card carte-liste <%= @carte_deroulee ? "carte--deroulee" : "" %>">
    <div class="fr-grid-row w-100 d-flex justify-content-between align-items-center">
      <div class='fr-col d-flex'>
        <span id="nom-<%= @ressource.id %>" class='carte__nom'><%= link_to @ressource.beneficiaire.nom.truncate(30), admin_evaluation_path(@ressource) %></span>
      </div>
      <%= render partial: "components/reponse_mise_en_action", locals: { evaluation: @ressource, affiche_qualification: false } %>
    </div>
  </div>
  <%= content %>
</li>
