<% profil = cafe_de_la_place ? cafe_de_la_place.niveau_litteratie : "indetermine" %>
<div class="panel panel--avec-references">
  <div class='marges-page'>
    <%= render "admin/evaluations_eva/litteratie_numeratie_synthese",
      synthese: synthese,
      scope: "admin.evaluations_eva.litteratie.#{profil}",
      icone: "icone_profil/icone_#{profil}.svg" %>
    <% if niveau_bas?(profil) %>
      <%= render "admin/evaluations_eva/positionnement/sous_competences",
        sous_competences: cafe_de_la_place.competences_litteratie,
        competence: :litteratie %>
    <% end %>
  </div>
  <%= render ReferentielAnlciComponent.new unless pdf %>
  <% if !pdf && cafe_de_la_place %>
    <% route = admin_positionnement_partie_reponses_path(partie_id: cafe_de_la_place.partie.id)%>
    <div class="padding-tuile">
      <%= render partial: "admin/evaluations_eva/telechargement_reponses", locals: { route: route } %>
    </div>
  <% end %>
</div>
