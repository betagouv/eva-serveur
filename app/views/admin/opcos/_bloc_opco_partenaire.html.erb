<% if opco.present? && opco.financeur? %>
  <div class="bloc-opco-partenaire">
    <h3 class="bloc-opco-partenaire__titre"><%= t(".titre") %></h3>
    <% if opco.logo.attached? %>
      <%= image_tag cdn_for(opco.logo.variant(:defaut)),
                    alt: opco.nom,
                    class: "bloc-opco-partenaire__logo" %>
    <% end %>
  </div>
<% end %>
