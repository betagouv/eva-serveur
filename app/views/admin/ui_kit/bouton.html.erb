<div class="fr-container">
  <div class="fr-mb-3w">
    <%= link_to "← Retour à l'index des composants", "/admin/ui_kit", class: "fr-link" %>
  </div>

  <h1 class="fr-h1 fr-mt-6w">Démo BoutonComponent</h1>

  <h2 class="fr-h2 fr-mt-6w">Bouton primaire</h2>
  <div style="display: flex; gap: 16px; align-items: flex-start; flex-wrap: wrap;">
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <span style="font-size: 12px; color: #666;">Défaut SM</span>
      <%= render BoutonComponent.new("#", type: :primary, size: :sm) do %>
        Libellé
      <% end %>
      <span style="font-size: 12px; color: #666;">Défaut MD</span>
      <%= render BoutonComponent.new("#", type: :primary, size: :md) do %>
        Libellé
      <% end %>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <span style="font-size: 12px; color: #666;">Hover SM</span>
      <%= render BoutonComponent.new("#", type: :primary, size: :sm, class: "bouton-hover-demo") do %>
        Libellé
      <% end %>
      <span style="font-size: 12px; color: #666;">Hover MD</span>
      <%= render BoutonComponent.new("#", type: :primary, size: :md, class: "bouton-hover-demo") do %>
        Libellé
      <% end %>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <span style="font-size: 12px; color: #666;">Désactivé SM</span>
      <%= render BoutonComponent.new("#", type: :desactive, size: :sm, class: "bouton--desactive") do %>
        Libellé
      <% end %>
      <span style="font-size: 12px; color: #666;">Désactivé MD</span>
      <%= render BoutonComponent.new("#", type: :desactive, size: :md, class: "bouton--desactive") do %>
        Libellé
      <% end %>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <span style="font-size: 12px; color: #666;">Icone SM</span>
      <%= render BoutonComponent.new("#", type: :primary, size: :sm) do %>
        <span class="fr-icon fr-icon--sm fr-icon-arrow-go-back-line" aria-label="Icône de bouton de retour arrière"></span>
        Libellé
      <% end %>
      <span style="font-size: 12px; color: #666;">Icone MD</span>
      <%= render BoutonComponent.new("#", type: :primary, size: :md) do %>
        <span class="fr-icon fr-icon--sm fr-icon-arrow-go-back-line" aria-label="Icône de bouton de retour arrière"></span>
        Libellé
      <% end %>
    </div>
  </div>

