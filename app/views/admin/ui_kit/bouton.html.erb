  <h2 class="fr-h2 fr-mt-6w">Avec paramètres supplémentaires</h2>
  <%= render BoutonComponent.new(
        "#",
        type: :primary,
        id: "mon-bouton",
        data: { test: "value" }
      ) do %>
    Bouton avec ID
  <% end %>
</div> 

