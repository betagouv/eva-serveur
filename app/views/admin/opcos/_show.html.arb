attributes_table_for opco do
  row :nom
  row :financeur
  row :logo do
    apercu_piece_jointe_avec_lien(opco.logo, variant: :defaut, fallback: "Aucun logo")
  end
  row :financeur do |opco|
    badge_financeur(opco)
  end
  row :telephone
  row :email
  row :url
  row :url_contact
  row :visuel_offre_services do
    apercu_piece_jointe_avec_lien(opco.visuel_offre_services, variant: :offre_services,
fallback: "Aucun visuel")
  end
  row :url_offre_services do
    if opco.url_offre_services.present?
      link_to opco.url_offre_services, opco.url_offre_services, target: "_blank", rel: "noopener"
    else
      span "Non renseigné"
    end
  end
  row :idcc do |opco|
    if opco.idcc.any?
      opco.idcc.join(", ")
    else
      "Aucun IDCC"
    end
  end
  row :created_at
end
