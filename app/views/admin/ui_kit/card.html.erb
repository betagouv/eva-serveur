<div class="container">
  <h1>Démo CardComponent</h1>

  <h2>Card simple avec titre</h2>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte",
        url: "#"
      ) %>
    </div>
  </div>

  <h2>Card avec titre et description</h2>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte",
        description: "Description de la carte",
        url: "#"
      ) %>
    </div>
  </div>

  <h2>Card avec titre, description et bouton</h2>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte",
        description: "Description de la carte",
        bouton_label: "Action",
        bouton_url: "#"
      ) %>
    </div>
  </div>

  <h2>Card avec image</h2>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte",
        description: "Description de la carte",
        image_url: image_path("avatar_salut.png"),
        image_alt: "Image de démonstration",
        url: "#"
      ) %>
    </div>
  </div>

  <h2>Card avec image, horizontale</h2>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte",
        description: "Description de la carte",
        image_url: image_path("avatar_salut.png"),
        image_alt: "Image de démonstration",
        url: "#",
        classes: ["fr-card--horizontal"],
        size: :sm
      ) %>
    </div>
  </div>

  <h2>Variantes de taille</h2>

  <h3>Card SM (petite)</h3>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte SM",
        description: "Description de la carte SM",
        size: :sm,
        url: "#"
      ) %>
    </div>
  </div>

  <h3>Card MD (moyenne - par défaut)</h3>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte MD",
        description: "Description de la carte MD",
        size: :md,
        url: "#"
      ) %>
    </div>
  </div>

  <h3>Card LG (grande)</h3>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte LG",
        description: "Description de la carte LG",
        size: :lg,
        url: "#"
      ) %>
    </div>
  </div>

  <h2>Exemple d'utilisation dans une grille</h2>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Carte 1",
        description: "Description de la première carte",
        url: "#"
      ) %>
    </div>
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Carte 2",
        description: "Description de la deuxième carte",
        url: "#"
      ) %>
    </div>
  </div>

  <h2>Card complète (titre, description, image, bouton)</h2>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col fr-col-md-6">
      <%= render CardComponent.new(
        titre: "Titre de la carte complète",
        description: "Description de la carte avec tous les éléments",
        image_url: image_path("avatar_salut.png"),
        image_alt: "Image de démonstration",
        bouton_label: "Action",
        bouton_url: "#"
      ) %>
    </div>
  </div>

  <h2>Les cartes d'usage de l'embarquement</h2>
  <div class="page-inscription-structure uik-max-792">
    <form>
      <div class="fr-grid-row fr-grid-row--gutters fr-mb-12v">
        <div class="fr-col-12 fr-col-sm-6 fr-col-lg-6">
          <%= render CardComponent.new(
            titre: t("inscription.structures.show.usage.eva.titre"),
            description: t("inscription.structures.show.usage.eva.description"),
            image_url: "logo/eva-card.svg",
            image_alt: t("header.eva.logo_alt"),
            url: "javascript:alert('eva a été choisi')",
            classes: [ "card-avec-logo card-avec-logo--eva" ]
          ) %>
        </div>
        <div class="fr-col-12 fr-col-sm-6 fr-col-lg-6">
          <%= render CardComponent.new(
            titre: t("inscription.structures.show.usage.evapro.titre"),
            description: t("inscription.structures.show.usage.evapro.description"),
            image_url: "logo/evapro-card.svg",
            image_alt: t("header.evapro.logo_alt"),
            url: "javascript:alert('evapro a été choisi')",
            classes: [ "card-avec-logo card-avec-logo--evapro" ]
          ) %>
        </div>
    </div>
    </form>
  </div>
</div>

