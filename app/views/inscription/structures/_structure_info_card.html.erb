    <li class="structure-info-card__info">
      <span class="structure-info-card__label"><%= Structure.human_attribute_name(:nom) %> :</span> <span class="structure-info-card__value"><%= structure&.nom %></span>
    </li>
    <li class="structure-info-card__info">
      <span class="structure-info-card__label"><%= Structure.human_attribute_name(:adresse) %> :</span> <span class="structure-info-card__value"><%= adresse_ou_code_postal(structure) %></span>
